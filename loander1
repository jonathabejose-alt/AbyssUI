if not isSupported then
    task.delay(1.8, function()
        Percent.Text = "Error"
        Progress:TweenSize(UDim2.new(1, 0, 1, 0), "Out", "Quad", 0.8)
        
        task.delay(1.5, function()
            animacionSalida()
            task.delay(0.6, function()
                ScreenGui:Destroy()
            end)
        end)
    end)
else
    local progress = 0
    
    task.delay(1.6, function()
        while progress < 100 and not cancelado do
            progress = progress + 20
            if progress > 100 then progress = 100 end
            
            local width = progress / 100
            Progress:TweenSize(UDim2.new(width, 0, 1, 0), "Out", "Quad", 0.3)
            Percent.Text = math.floor(progress) .. "%"
            
            if progress >= 80 then
                Status.Text = "✓ Launching " .. gameInfo.name .. "..."
            elseif progress >= 60 then
                Status.Text = "✓ Loading scripts..."
            elseif progress >= 40 then
                Status.Text = "✓ Initializing modules..."
            elseif progress >= 20 then
                Status.Text = "✓ " .. gameInfo.name .. " detected!"
            end
            
            task.wait(0.6)
        end
        
        if cancelado then return end
        
        Status.Text = "✓ Complete!"
        Percent.TextColor3 = Color3.fromRGB(100, 255, 150)
        
        task.wait(0.5)
        
        animacionSalida()
        
        task.delay(0.6, function()
            ScreenGui:Destroy()
            if scriptURL ~= "" then
                loadstring(game:HttpGet(scriptURL))()
            end
        end)
    end)
end
