local logLines = {}
local logY = 16

local function createLogLine(text, color, delay)
    local line = Instance.new("TextLabel")
    line.Size = UDim2.new(1, -24, 0, 18)
    line.Position = UDim2.new(0, 12, 0, logY)
    line.BackgroundTransparency = 1
    line.Text = ""
    line.TextColor3 = color or Color3.fromRGB(0, 255, 70)
    line.Font = Enum.Font.Code
    line.TextSize = 13
    line.TextXAlignment = Enum.TextXAlignment.Left
    line.TextTransparency = 1
    line.Parent = Content
    logY = logY + 22
    table.insert(logLines, {label = line, text = text, delay = delay})
    return line
end

