local particles = {}
for i = 1, 100 do
    local particle = Instance.new("Frame")
    local size = math.random(2, 5)
    particle.Size = UDim2.new(0, size, 0, size)
    particle.Position = UDim2.new(math.random(), 0, math.random(), 0)
    local colors = {
        Color3.fromRGB(150, 0, 255),
        Color3.fromRGB(100, 0, 200),
        Color3.fromRGB(200, 0, 255),
        Color3.fromRGB(80, 0, 180)
    }
    particle.BackgroundColor3 = colors[math.random(1, #colors)]
    particle.BackgroundTransparency = math.random(60, 90) / 100
    particle.BorderSizePixel = 0
    particle.Parent = ScreenGui
    particle.Visible = false
    Instance.new("UICorner", particle).CornerRadius = UDim.new(1, 0)
    
    task.spawn(function()
        local speed = math.random(4, 10)
        local startPos = particle.Position
        local endPos = UDim2.new(math.random(), 0, math.random(), 0)
        
        while particle.Parent do
            TweenService:Create(particle, TweenInfo.new(speed, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Position = endPos,
                BackgroundTransparency = math.random(40, 70) / 100
            }):Play()
            task.wait(speed)
            TweenService:Create(particle, TweenInfo.new(speed, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Position = startPos,
                BackgroundTransparency = math.random(70, 95) / 100
            }):Play()
            task.wait(speed)
        end
    end)
    
    table.insert(particles, particle)
end

