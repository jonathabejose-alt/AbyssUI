local function animacionSalida()
    TweenService:Create(Border, TweenInfo.new(0.2), {Transparency = 1}):Play()
    
    TweenService:Create(Title, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
    TweenService:Create(TitleShadow, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
    TweenService:Create(Status, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
    TweenService:Create(Percent, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
    
    TweenService:Create(Progress, TweenInfo.new(0.2), {Size = UDim2.new(0, 0, 1, 0)}):Play()
    TweenService:Create(BarBg, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
    
    TweenService:Create(IconContainer, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Rotation = 360
    }):Play()
    TweenService:Create(IconGlow, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
    
    for _, v in ipairs(particles) do
        TweenService:Create(v, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
    end
    
    for _, ring in ipairs(rings) do
        TweenService:Create(ring, TweenInfo.new(0.3), {
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 0, 0, 0)
        }):Play()
    end
    
    TweenService:Create(BackGlow, TweenInfo.new(0.3), {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 0, 0, 0)
    }):Play()
    
    TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Rotation = 45,
        BackgroundTransparency = 1
    }):Play()
    
    TweenService:Create(Background, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
end

