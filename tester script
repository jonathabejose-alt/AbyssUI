local playerESPHL  = {}
local playerESPBB  = {}
local playerESPConn= nil

local function addPlayerESP(p)
    if p == player then return end
    local uid  = p.UserId
    if playerESPHL[uid] then return end
    local char = p.Character
    if not char then return end

    local hl = Instance.new("Highlight")
    hl.FillColor           = Color3.fromRGB(70, 135, 255)
    hl.FillTransparency    = 0.82
    hl.OutlineColor        = Color3.fromRGB(105, 170, 255)
    hl.OutlineTransparency = 0.12
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee = char; hl.Parent = char
    playerESPHL[uid] = hl

    local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    if head then
        local bb = Instance.new("BillboardGui")
        bb.Size        = UDim2.new(0, 200, 0, 20)
        bb.StudsOffset = Vector3.new(0, 3.5, 0)
        bb.AlwaysOnTop = true
        bb.Adornee     = head
        bb.Parent      = head
        local lbl = Instance.new("TextLabel")
        lbl.Size                   = UDim2.fromScale(1, 1)
        lbl.BackgroundTransparency = 1
        lbl.Text                   = p.DisplayName
        lbl.TextColor3             = Color3.fromRGB(105, 170, 255)
        lbl.TextSize               = 13
        lbl.Font                   = Enum.Font.GothamBold
        lbl.TextStrokeTransparency = 0.5
        lbl.TextStrokeColor3       = Color3.new(0, 0, 0)
        lbl.Parent = bb
        playerESPBB[uid] = bb
    end
end

local function removePlayerESP(p)
    local uid = p.UserId
    if playerESPHL[uid] then playerESPHL[uid]:Destroy(); playerESPHL[uid] = nil end
    if playerESPBB[uid] then playerESPBB[uid]:Destroy(); playerESPBB[uid] = nil end
end

local function clearAllESP()
    for uid, hl in pairs(playerESPHL) do if hl then pcall(function() hl:Destroy() end) end; playerESPHL[uid] = nil end
    for uid, bb in pairs(playerESPBB) do if bb then pcall(function() bb:Destroy() end) end; playerESPBB[uid] = nil end
end

