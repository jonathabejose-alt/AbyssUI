local function findPlayer(plr)
    if typeof(plr) == "Instance" then return plr end
    if typeof(plr) == "string" then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name == plr or p.DisplayName == plr then return p end
        end
    end
    return nil
end

local function enableFreecamMode()
    if freecamActive then return end
    freecamActive = true
    freecamPart = Instance.new("Part")
    freecamPart.Anchored = true
    freecamPart.Transparency = 1
    freecamPart.CanCollide = false
    freecamPart.Size = Vector3.new(1, 1, 1)
    freecamPart.CFrame = camera.CFrame
    freecamPart.Parent = workspace
    camera.CameraType = Enum.CameraType.Scriptable
    camera.CFrame = freecamPart.CFrame
end

local function disableFreecamMode()
    freecamActive = false
    camera.CameraType = Enum.CameraType.Custom
    local hum = getHum()
    if hum then camera.CameraSubject = hum end
    if freecamPart then freecamPart:Destroy(); freecamPart = nil end
end

local function stopKillAll()
    killAllLooping = false
end

local function startKillAll()
    if killAllLooping then return end
    killAllLooping = true
    task.spawn(function()
        while killAllLooping do
            local myHRP = getRoot()
            if not myHRP then task.wait(0.1); continue end
            for _, target in ipairs(Players:GetPlayers()) do
                if not killAllLooping then break end
                if target == player or not target.Character then continue end
                local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
                if tHRP then
                    myHRP.CFrame = tHRP.CFrame * CFrame.new(0, 0, 0.8)
                    RunService.Heartbeat:Wait()
                end
            end
            task.wait(0.02)
        end
    end)
end

local function stopMahitoLoop()
