local inviteLoopId = 0
qolSection:Input({
    Title       = "Better Inviting",
    Desc        = "Use in Duel Queue. Filters invite list by username.",
    Placeholder = "Enter username...",
    Callback    = function(v)
        inviteLoopId += 1
        local currentLoop = inviteLoopId
        task.spawn(function()
            while currentLoop == inviteLoopId do
                local gui       = player:FindFirstChild("PlayerGui")
                local container = gui
                    and gui:FindFirstChild("Ranked")
                    and gui.Ranked:FindFirstChild("Invite")
                    and gui.Ranked.Invite:FindFirstChild("Players")
                if container then
                    local children = container:GetChildren()
                    for _, frame in ipairs(children) do
                        if frame:IsA("Frame") then frame.Visible = true end
                    end
                    for _, frame in ipairs(children) do
                        task.defer(function()
                            if currentLoop ~= inviteLoopId then return end
                            if frame:IsA("Frame")
                               and not string.find(string.lower(frame.Name), string.lower(v)) then
                                frame.Visible = false
                            end
                        end)
                    end
                end
                RunService.RenderStepped:Wait()
            end
        end)
    end,
})

