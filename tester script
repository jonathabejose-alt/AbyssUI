local antiDomainEnabled  = false
local domainActiveTarget = nil
local domainLerpStart    = nil
local domainLerpEnd      = nil
local domainLerpTime     = 0.8
local domainLerpProgress = 0

local domainAnimIds = {
    "rbxassetid://132725601768618",
    "rbxassetid://118861398234801",
    "rbxassetid://73048386765082",
    "rbxassetid://80922461169812",
    "rbxassetid://121984128639453",
    "rbxassetid://125335594549446",
    "rbxassetid://83241775239139",
}

local function isDomainAnimPlaying(hum)
    for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
        for _, id in ipairs(domainAnimIds) do
            if track.Animation and track.Animation.AnimationId == id then return true end
        end
    end
    return false
end

local domainHRP = getRoot()
player.CharacterAdded:Connect(function(c)
    domainHRP = c:WaitForChild("HumanoidRootPart")
end)

RunService.RenderStepped:Connect(function(dt)
    if not antiDomainEnabled or not domainHRP then return end

    if domainActiveTarget and domainLerpProgress < domainLerpTime then
        domainLerpProgress += dt
        local alpha   = math.clamp(domainLerpProgress / domainLerpTime, 0, 1)
        local startCF = CFrame.new(domainLerpStart, domainLerpStart + domainHRP.CFrame.LookVector)
        local endCF   = CFrame.new(domainLerpEnd,   domainLerpEnd   + domainHRP.CFrame.LookVector)
        domainHRP.CFrame = startCF:Lerp(endCF, alpha)
        return
    end

    if domainActiveTarget then
        local tHRP = domainActiveTarget:FindFirstChild("HumanoidRootPart")
        if not tHRP or (domainHRP.Position - tHRP.Position).Magnitude > 75 then
            domainActiveTarget = nil
            domainLerpStart    = nil
            domainLerpEnd      = nil
            domainLerpProgress = 0
        end
    end

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local oc   = p.Character
            local oHRP = oc and oc:FindFirstChild("HumanoidRootPart")
            local oHum = oc and oc:FindFirstChildOfClass("Humanoid")
            if oHRP and oHum then
                local dist = (domainHRP.Position - oHRP.Position).Magnitude
                if dist <= 50 and isDomainAnimPlaying(oHum) then
                    local dir = (domainHRP.Position - oHRP.Position).Unit
                    domainActiveTarget = oc
                    domainLerpStart    = domainHRP.Position
                    domainLerpEnd      = oHRP.Position + dir * 75
                    domainLerpProgress = 0
                    break
                end
            end
        end
    end
end)

