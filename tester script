funSection:Button({
    Title = "Call Train",
    Desc  = "Calls the train at the station.",
    Icon  = "train",
    Callback = function()
        local hrp = getRoot()
        if not hrp then return end
        hrp:SetAttribute("ReturnPosition", hrp.Position)
        local ok, err = pcall(function()
            local button = workspace:WaitForChild("Map")
                :WaitForChild("Destructible"):WaitForChild("Model")
                :WaitForChild("StationControl"):WaitForChild("ButtonTrain")
                :WaitForChild("Button")
            hrp.CFrame = button.CFrame + Vector3.new(0, 3, 0)
            task.wait(0.1)
            local prompt = button:FindFirstChildWhichIsA("ProximityPrompt")
            if prompt then
                prompt.HoldDuration = 0
                fireproximityprompt(prompt)
            end
            task.wait(1)
            local rp = hrp:GetAttribute("ReturnPosition")
            if rp then hrp.CFrame = CFrame.new(rp) end
        end)
        if ok then notify("Call Train", "Train called!", "train")
        else notify("Call Train", "Failed: " .. tostring(err), "alert-triangle", 5) end
    end,
})


local climbConn = nil
funSection:Toggle({
    Title = "Climb Walls",
    Desc  = "Hold W facing a wall to climb it.",
    Icon  = "layers", Type = "Toggle", Value = false,
    Callback = function(s)
        if climbConn then climbConn:Disconnect(); climbConn = nil end
        if not s then notify("Climb Walls", "Disabled.", "layers"); return end

        climbConn = RunService.RenderStepped:Connect(function()
            local char = getChar()
            local hrp  = getRoot()
            local hum  = getHum()
            if not char or not hrp or not hum then return end
            local climbing = false

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                local params = RaycastParams.new()
                params.FilterDescendantsInstances = { char }
                params.FilterType = Enum.RaycastFilterType.Blacklist
                local result = workspace:Raycast(
                    hrp.Position + Vector3.new(0, 2, 0),
                    hrp.CFrame.LookVector * 2,
                    params
                )
                if result and result.Normal.Y == 0 then
                    hum.PlatformStand = false
                    hrp.Velocity = Vector3.new(0, 25, 0)
                    climbing = true
                    if not char:FindFirstChild("ClimbAnim") then
                        local a = Instance.new("Animation")
                        a.AnimationId = "rbxassetid://180436334"
                        a.Name = "ClimbAnim"; a.Parent = char
                    end
                    local playing = false
                    for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
                        if track.Animation.AnimationId == "rbxassetid://180436334" then playing = true end
                        if track.Animation.AnimationId == "rbxassetid://180436117" then track:Stop() end
                    end
                    if not playing then
                        hum:LoadAnimation(char:FindFirstChild("ClimbAnim")):Play()
                    end
                end
            end

            if not climbing then
                for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
                    if track.Animation.AnimationId == "rbxassetid://180436334" then track:Stop() end
                end
            end
        end)
        notify("Climb Walls", "Enabled. Hold W facing a wall.", "layers")
    end,
})

