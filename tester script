lockSection:Toggle({
    Title = "Lock On",
    Desc  = "RMB = lock closest. RMB again = unlock.",
    Icon  = "crosshair", Type = "Toggle", Value = false,
    Callback = function(s)
        lockOnEnabled = s
        notify("Lock On", s and "Enabled. RMB to lock." or "Disabled.", "crosshair")

        if s then
            lockInputConn = UserInputService.InputBegan:Connect(function(input, gp)
                if gp then return end
                if input.UserInputType ~= Enum.UserInputType.MouseButton2 then return end

                if lockedTarget then
                    lockedTarget = nil
