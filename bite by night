    BoxBorder = true,
})

local antiDeath = {
    enabled    = false,
    threshold  = 30,
    conn       = nil,
    lastPos    = nil,
    teleported = false,
    debounce   = false,
    plate      = nil,
}
local adSpeed = 10

local function getADRoot()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

local function adLerp(targetCF)
    local root     = getADRoot()
    local startCF  = root.CFrame
    local dist     = (startCF.Position - targetCF.Position).Magnitude
    local duration = dist / adSpeed
    local t        = 0
    while t < duration do
        t += RunService.Heartbeat:Wait()
        root.CFrame = startCF:Lerp(targetCF, math.clamp(t / duration, 0, 1))
    end
    root.CFrame = targetCF
end

local function returnToLastPos()
    if antiDeath.plate then antiDeath.plate:Destroy(); antiDeath.plate = nil end
    if antiDeath.lastPos then task.spawn(function() adLerp(antiDeath.lastPos) end) end
    antiDeath.lastPos    = nil
    antiDeath.teleported = false
end

