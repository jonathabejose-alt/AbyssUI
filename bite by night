TpsTab:Section({ Title = "Teleport Features" })

-- Generator TP
local generatorIndex = 1

local function getOrderedGenerators()
    local folder = workspace.MAPS["GAME MAP"].Generators
    local models = {}
    for _, v in ipairs(folder:GetChildren()) do
        if v:IsA("Model") then table.insert(models, v) end
    end
    return models
end

TpsTab:Button({
    Title    = "Generator TP",
    Desc     = "Se teleporta a cada generador uno por uno.",
    Callback = function()
        local models = getOrderedGenerators()
        if #models == 0 then return end
        local model = models[generatorIndex]
        local part  = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
        if part then
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = CFrame.new(part.CFrame.Position + part.CFrame.LookVector * 5)
            end
        end
        generatorIndex = generatorIndex % #models + 1
        notify("Generator TP", "Teleported to generator " .. tostring(generatorIndex))
    end
})

-- Battery TP
local batteryIndex = 1

local function getBatteries()
    local batteries = {}
    local ignore    = workspace:FindFirstChild("IGNORE")
    if not ignore then return batteries end
    for _, v in ipairs(ignore:GetDescendants()) do
        if v:IsA("MeshPart") and v.Name == "Battery" then
            table.insert(batteries, v)
        end
    end
    return batteries
end

TpsTab:Button({
    Title    = "Battery TP",
    Desc     = "Se teleporta a cada batería una por una.",
    Callback = function()
        local batteries = getBatteries()
        if #batteries == 0 then return end
        local battery = batteries[batteryIndex]
        local root    = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = battery.CFrame + Vector3.new(0, 3, 0)
        end
        batteryIndex = batteryIndex % #batteries + 1
        notify("Battery TP", "Teleported to battery " .. tostring(batteryIndex))
    end
})

