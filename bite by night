local espTable = {}

-- Survivor ESP
VisTab:Toggle({
    Title    = "Survivor ESP",
    Desc     = "Highlight All Survivors.",
    Default  = false,
    Callback = function(state)
        if state then
            espTable.Survivors = true
            local function highlightSurvivor(char)
                if espTable[char] then return end
                local h = Instance.new("Highlight")
                h.Name               = "SurvivorHighlight"
                h.FillColor          = Color3.fromRGB(80, 180, 255)
                h.OutlineColor       = Color3.fromRGB(120, 200, 255)
                h.FillTransparency   = 0.5
                h.OutlineTransparency= 0
                h.DepthMode          = Enum.HighlightDepthMode.AlwaysOnTop
                h.Adornee            = char
                h.Parent             = char
                espTable[char]       = h
            end
            local aliveFolder = workspace.PLAYERS.ALIVE
            for _, char in ipairs(aliveFolder:GetChildren()) do
                if char:IsA("Model") then highlightSurvivor(char) end
            end
            espTable.SurvivorConnection = aliveFolder.ChildAdded:Connect(function(char)
                if espTable.Survivors and char:IsA("Model") then highlightSurvivor(char) end
            end)
            espTable.SurvivorRemove = aliveFolder.ChildRemoved:Connect(function(char)
                if espTable[char] then espTable[char]:Destroy() espTable[char] = nil end
            end)
            notify("Survivor ESP", "Enabled.")
        else
            espTable.Survivors = false
            if espTable.SurvivorConnection then espTable.SurvivorConnection:Disconnect() espTable.SurvivorConnection = nil end
            if espTable.SurvivorRemove     then espTable.SurvivorRemove:Disconnect()     espTable.SurvivorRemove     = nil end
            for model, highlight in pairs(espTable) do
                if typeof(model) == "Instance" and highlight and typeof(highlight) == "Instance" and highlight.Parent
                    and model:IsDescendantOf(workspace.PLAYERS.ALIVE) then
                    highlight:Destroy()
                    espTable[model] = nil
                end
            end
            notify("Survivor ESP", "Disabled.")
        end
    end
})

