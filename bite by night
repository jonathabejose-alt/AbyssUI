mainSection:Toggle({
    Title = "Allow Jumping",
    Desc  = "Allows You To Jump.",
    Icon  = "arrow-up",
    Type  = "Toggle",
    Value = false,
    Callback = function(state)
        jumpBoost = state
        if jumpBoost then
            local function applyJumpPower()
                local char = player.Character
                if not char then return end
