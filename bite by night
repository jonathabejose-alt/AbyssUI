-- ── Aimlock ───────────────────────────────────────────────────────────────────
local aimlockEnabled   = false
local lockedTarget     = nil
local inputConnection  = nil
local renderConnection = nil
local camera           = workspace.CurrentCamera
local aimlockBind      = Enum.UserInputType.MouseButton2

local function getMyTeamFolder()
    local char = player.Character
    if not char then return nil end
    local playersFolder = workspace:FindFirstChild("PLAYERS")
    local aliveFolder   = playersFolder and playersFolder:FindFirstChild("ALIVE")
    local killerFolder  = playersFolder and playersFolder:FindFirstChild("KILLER")
    if aliveFolder  and char.Parent == aliveFolder  then return "ALIVE"  end
    if killerFolder and char.Parent == killerFolder then return "KILLER" end
    return nil
end

mainSection:Toggle({
    Title = "Aimlock",
    Desc  = "Locks Your Camera Onto The Closest Enemy On Bind Press.",
    Icon  = "crosshair",
    Type  = "Toggle",
    Value = false,
    Callback = function(state)
        aimlockEnabled = state
        notify("Aimlock", state and "Enabled." or "Disabled.", "crosshair")
        if state then
            inputConnection = UserInputService.InputBegan:Connect(function(input, gp)
                if gp then return end
                if input.UserInputType ~= aimlockBind and input.KeyCode ~= aimlockBind then return end
                if lockedTarget then lockedTarget = nil; return end
                local myTeam = getMyTeamFolder()
                if not myTeam then return end
                local myChar = player.Character
                if not myChar then return end
                local myRoot = myChar:FindFirstChild("HumanoidRootPart")
                if not myRoot then return end
                local targetFolderName = (myTeam == "ALIVE") and "KILLER" or "ALIVE"
                local playersFolder    = workspace:FindFirstChild("PLAYERS")
                local targetFolder     = playersFolder and playersFolder:FindFirstChild(targetFolderName)
                if not targetFolder then return end
                local closest, shortest = nil, math.huge
                for _, other in ipairs(Players:GetPlayers()) do
                    if other ~= player and other.Character
                       and other.Character.Parent == targetFolder then
                        local root = other.Character:FindFirstChild("HumanoidRootPart")
                        if root then
                            local dist = (myRoot.Position - root.Position).Magnitude
                            if dist < shortest then shortest = dist; closest = root end
                        end
                    end
                end
                if closest then lockedTarget = closest end
            end)
            renderConnection = RunService.RenderStepped:Connect(function()
                if lockedTarget and lockedTarget.Parent then
                    camera.CFrame = CFrame.new(camera.CFrame.Position, lockedTarget.Position)
                else
                    lockedTarget = nil
                end
            end)
        else
            lockedTarget = nil
            if inputConnection  then inputConnection:Disconnect();  inputConnection  = nil end
            if renderConnection then renderConnection:Disconnect(); renderConnection = nil end
        end
    end
})

mainSection:Input({
    Title       = "Aimlock Bind",
    Desc        = "Enter Key (e.g. LeftAlt, MouseButton2). Must be capitalized.",
    Placeholder = "MouseButton2",
    Callback    = function(text)
        if typeof(text) ~= "string" then
            aimlockBind = Enum.UserInputType.MouseButton2
            notify("Aimlock Bind", "Invalid input. Bind reset to M2.", "alert-triangle")
            return
        end
        local formatted = text:gsub("%s+", "")
        local ok1, key = pcall(function() return Enum.KeyCode[formatted] end)
        if ok1 and key then
            aimlockBind = key
            notify("Aimlock Bind", "Bind set to: " .. key.Name, "check")
            return
        end
        local ok2, itype = pcall(function() return Enum.UserInputType[formatted] end)
        if ok2 and itype then
            aimlockBind = itype
            notify("Aimlock Bind", "Bind set to: " .. itype.Name, "check")
        else
            aimlockBind = Enum.UserInputType.MouseButton2
            notify("Aimlock Bind", "Invalid input. Bind reset to M2.", "alert-triangle")
        end
    end,
})

