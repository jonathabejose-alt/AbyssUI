-- Full Bright
local fullBrightEnabled = false
local originalLighting  = {}
local fullBrightConn    = nil

MiscTab:Toggle({
    Title    = "Full Bright",
    Desc     = "Activate full brightness across the entire map.",
    Default  = false,
    Callback = function(state)
        local Lighting = game:GetService("Lighting")
        if state then
            originalLighting = {
                Ambient           = Lighting.Ambient,
                Brightness        = Lighting.Brightness,
                ColorShift_Bottom = Lighting.ColorShift_Bottom,
                ColorShift_Top    = Lighting.ColorShift_Top,
                OutdoorAmbient    = Lighting.OutdoorAmbient,
                ShadowSoftness    = Lighting.ShadowSoftness,
                GlobalShadows     = Lighting.GlobalShadows,
                FogEnd            = Lighting.FogEnd,
            }
            local function applyFullBright()
                Lighting.Ambient           = Color3.new(1, 1, 1)
                Lighting.Brightness        = 3
                Lighting.ColorShift_Bottom = Color3.new(1, 1, 1)
                Lighting.ColorShift_Top    = Color3.new(1, 1, 1)
                Lighting.OutdoorAmbient    = Color3.new(1, 1, 1)
                Lighting.ShadowSoftness    = 0
                Lighting.GlobalShadows     = false
                Lighting.FogEnd            = 100000
            end
            applyFullBright()
            fullBrightConn = RunService.Heartbeat:Connect(function()
                if not fullBrightEnabled then return end
                if Lighting.Brightness ~= 3 or Lighting.GlobalShadows ~= false then
                    applyFullBright()
                end
            end)
            fullBrightEnabled = true
            notify("Full Bright", "Enabled.", 2)
        else
            fullBrightEnabled = false
            if fullBrightConn then fullBrightConn:Disconnect() fullBrightConn = nil end
            for prop, value in pairs(originalLighting) do
                pcall(function() Lighting[prop] = value end)
            end
            notify("Full Bright", "Disabled.", 2)
        end
    end
})

