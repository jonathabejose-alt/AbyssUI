local function newHighlight(obj, color)
    if not obj then return end
    local h = Instance.new("Highlight")
    h.FillColor           = color
    h.FillTransparency    = 0.5
    h.OutlineColor        = color
    h.OutlineTransparency = 0
    h.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee = obj
    h.Parent  = obj
    return h
end

local function createDrawingBox(color)
    local box = Drawing.new("Square")
    box.Color        = color
    box.Thickness    = 2
    box.Filled       = false
    box.Transparency = 1
    return box
end

local function updateDrawingBox(box, obj)
    if not box or not obj then return end
    local root = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
    if not root then box.Visible = false; return end
    local cam = workspace.CurrentCamera
    local vec, onScreen = cam:WorldToViewportPoint(root.Position)
    if onScreen then
        local size = (cam:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)) - vec).Y * 2.5
        box.Size     = Vector2.new(size * 1.2, size)
        box.Position = Vector2.new(vec.X - box.Size.X / 2, vec.Y - box.Size.Y / 2)
        box.Visible  = true
    else
        box.Visible = false
    end
end

-- ── Health Labels ─────────────────────────────────────────────────────────────
local healthLabels = {}

local function createHealthLabel(char)
    if not char or healthLabels[char] then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    local labelGui = Instance.new("BillboardGui")
    labelGui.Adornee      = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    labelGui.Size         = UDim2.new(3, 0, 1, 0)
    labelGui.StudsOffset  = Vector3.new(0, 3, 0)
    labelGui.AlwaysOnTop  = true
    labelGui.LightInfluence = 0
    labelGui.Parent       = char
    local textLabel = Instance.new("TextLabel")
    textLabel.Size                   = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3             = Color3.fromRGB(255, 255, 255)
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3       = Color3.fromRGB(0, 0, 0)
    textLabel.Font                   = Enum.Font.GothamBold
    textLabel.TextSize               = 16
    textLabel.Text                   = "100 / 100"
    textLabel.Parent                 = labelGui
    healthLabels[char] = { gui = labelGui, text = textLabel, humanoid = humanoid, connection = nil }
    local conn = humanoid.HealthChanged:Connect(function()
        if not healthLabels[char] then conn:Disconnect(); return end
        healthLabels[char].text.Text = math.floor(humanoid.Health) .. " / " .. math.floor(humanoid.MaxHealth)
    end)
    healthLabels[char].connection = conn
    textLabel.Text = math.floor(humanoid.Health) .. " / " .. math.floor(humanoid.MaxHealth)
end

local function removeHealthLabel(char)
    if not healthLabels[char] then return end
    if healthLabels[char].connection then healthLabels[char].connection:Disconnect() end
    if healthLabels[char].gui        then healthLabels[char].gui:Destroy()           end
    healthLabels[char] = nil
end

local function addESP(tbl, obj, color)
    if not obj or tbl[obj] then return end
    if espMethod == "Dual" then
        tbl[obj] = {
            highlight = newHighlight(obj, color),
            drawing   = createDrawingBox(color),
        }
    elseif espMethod == "Highlight" then
        tbl[obj] = newHighlight(obj, color)
    else
        tbl[obj] = createDrawingBox(color)
    end
    if tbl == esp.survivors then
        createHealthLabel(obj)
    end
end

local function removeESP(tbl, obj)
    if not tbl[obj] then return end
    if typeof(tbl[obj]) == "table" then
        if tbl[obj].highlight then tbl[obj].highlight:Destroy() end
        if tbl[obj].drawing   then tbl[obj].drawing:Remove()   end
    elseif typeof(tbl[obj]) == "Instance" then
        tbl[obj]:Destroy()
    else
        tbl[obj]:Remove()
    end
    tbl[obj] = nil
    removeHealthLabel(obj)
end

local function clearESP(tbl)
    for obj, v in pairs(tbl) do
        if v then
            if typeof(v) == "table" then
                if v.highlight then v.highlight:Destroy() end
                if v.drawing   then v.drawing:Remove()   end
            elseif typeof(v) == "Instance" then
                v:Destroy()
            else
                v:Remove()
            end
        end
        tbl[obj] = nil
        removeHealthLabel(obj)
    end
end

RunService.RenderStepped:Connect(function()
    if espMethod ~= "Drawing" and espMethod ~= "Dual" then return end
    for _, tbl in pairs({ esp.survivors, esp.killers, esp.generators }) do
        for obj, data in pairs(tbl) do
            if typeof(data) == "table" and data.drawing then
                updateDrawingBox(data.drawing, obj)
            elseif typeof(data) ~= "Instance" then
                updateDrawingBox(data, obj)
            end
        end
    end
end)

