-- SKILL 2 - TRAP SHOT
-- ======================
local function TrapShot()
    local char = plr.Character
    if not char or Stunned() or not HasBall() or IsOnCD("skill2") then return end
    CancelMove()
    DoCD("skill2", 20)
    local humanoid = char.Humanoid
    local root = char.HumanoidRootPart
